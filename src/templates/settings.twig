{% import '_includes/forms' as forms %}

{{ forms.lightswitchField({
    first: true,
    label: 'Enable Google OAuth'|t('app'),
    name: 'active',
    on: settings.active
}) }}

{{ forms.autosuggestField({
    first: true,
    label: "Google OAuth ID"|t('app'),
    name: 'clientID',
    required: true,
    suggestEnvVars: true,
    value: settings.clientID
}) }}

{{ forms.autosuggestField({
    first: true,
    label: "Google OAuth Secret"|t('app'),
    name: 'clientSecret',
    required: true,
    suggestEnvVars: true,
    value: settings.clientSecret
}) }}

{{ forms.lightswitchField({
    label: 'Disable native login'|t('app'),
    instructions: 'Disable usr/pw and passkey login methods.<br><small><strong>Make sure Google OAuth is fully setup before enabling this.</strong></small>'|t('app'),
    first: true,
    name: 'disableLogin',
    on: settings.disableLogin
}) }}
